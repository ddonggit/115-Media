# 115-Media Environment Configuration
# Copy this file to .env and fill in your values.

REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite+aiosqlite:///./data/115-media.db

# TMDB API Key (required) — get yours at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# 115 Cookie (optional — set via login flow at /login page)
P115_COOKIE=

# JWT Secret Key (change in production!)
SECRET_KEY=change-me-in-production-please

# Admin credentials (change in production!)
# ADMIN_USER=admin
# ADMIN_PASSWORD=your-secure-password-here

# WebSocket URL (used by frontend, defaults to auto-detect)
# VITE_WS_URL=ws://localhost:8000/ws

